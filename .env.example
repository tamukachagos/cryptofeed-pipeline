# =============================================
# CryptoFeed Pipeline — Zero-Trust Configuration
# =============================================
#
# Production REQUIRED vars (system refuses to start without these):
#   ENVIRONMENT=production
#   SECRET_ENCRYPTION_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
#   REDIS_PASSWORD=<strong random password>
#
# Production vars that disable controls if missing (logged as FATAL):
#   INTERNAL_API_SECRET
#   STRIPE_WEBHOOK_SECRET
#   STRIPE_SECRET_KEY
#
# =============================================

# Deployment environment: production | staging | development
# In production: BYPASS_AUTH=true and missing SECRET_ENCRYPTION_KEY cause hard exit
ENVIRONMENT=development

# Exchange API keys (optional - all data is from public endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_production   # REQUIRED: AUTH password — set before deployment
REDIS_STREAM_MAXLEN=100000

# Secret encryption key for api_secret at-rest encryption (Fernet)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production — system exits without it
SECRET_ENCRYPTION_KEY=

# Data storage (use absolute path on VM e.g. /data)
DATA_DIR=./data
PARQUET_COMPRESSION=zstd

# Symbols to collect (comma-separated)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# Exchanges to enable
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_OKX=true

# Processor flush settings
PARQUET_FLUSH_ROWS=10000
PARQUET_FLUSH_SECS=60

# API server
# Set to true ONLY for local development (skips API key auth)
BYPASS_AUTH=false
# Set to true ONLY for local development (exposes /docs and /redoc)
ENABLE_DOCS=false
# Max auth failures per IP per minute before blocking (default 20)
AUTH_FAIL_LIMIT=20

# Stripe billing integration
STRIPE_SECRET_KEY=sk_live_...        # required for billing endpoints
STRIPE_WEBHOOK_SECRET=whsec_...      # required to verify webhook signatures
STRIPE_PRO_PRICE_ID=price_...        # Stripe Price ID for Pro plan
STRIPE_ENTERPRISE_PRICE_ID=price_... # Stripe Price ID for Enterprise plan

# Internal admin API
INTERNAL_API_SECRET=                 # shared secret for /internal/* endpoints
INTERNAL_ALLOWED_IPS=                # comma-separated IPs allowed to call /internal/* (empty = any IP)

# HMAC request signing (optional — enforces signed requests for high-security clients)
HMAC_REQUIRED=false                  # set to true to require HMAC on all requests
HMAC_MAX_CLOCK_SKEW_S=30             # reject requests timestamped >N seconds from server time

# Request body size limit
MAX_REQUEST_BODY_BYTES=1048576       # 1 MB default; rejects oversized POST bodies with 413

# Economic abuse controls
CURSOR_BURST_LIMIT=20                # cursor requests per 60s before scraping detection fires
CURSOR_PENALTY_S=300                 # penalty Retry-After in seconds when scraping detected

# Internal endpoint IP allowlist (comma-separated; empty = any IP with correct secret)
# Strongly recommended to set to your private subnet, e.g. 10.0.0.0/8
INTERNAL_ALLOWED_IPS=

# AI agents — get key at console.anthropic.com
ANTHROPIC_API_KEY=

# Vercel agent — get token at vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT=cryptofeed-web
VERCEL_TEAM=                        # leave blank for personal accounts

# ── PostgreSQL (production) ────────────────────────────────────────────────────
# Leave unset to use SQLite (development default).
# Set to switch all database operations to PostgreSQL.
DATABASE_URL=                        # e.g. postgresql://user:pass@host:5432/cryptofeed

# ── AWS KMS (optional — overrides SECRET_ENCRYPTION_KEY if set) ───────────────
AWS_KMS_KEY_ID=                      # KMS key ARN or alias
AWS_KMS_CIPHERTEXT=                  # base64 ciphertext blob from: aws kms encrypt ...
AWS_REGION=us-east-1

# ── HashiCorp Vault (optional — overrides SECRET_ENCRYPTION_KEY if set) ───────
VAULT_ADDR=                          # e.g. https://vault.example.com
VAULT_TOKEN=                         # Vault auth token
VAULT_SECRET_PATH=                   # e.g. secret/data/cryptofeed
VAULT_SECRET_KEY=encryption_key      # field name within the secret

# ── Email (SMTP) — required for /billing/request-verify OTP ──────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cryptodataapi.dev
SMTP_TLS=starttls                    # starttls | ssl | none

# ── Cloudflare Turnstile CAPTCHA — /billing/checkout ─────────────────────────
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
CF_TURNSTILE_SECRET_KEY=             # server-side secret key (keep private)
# CF_TURNSTILE_SITE_KEY is used in the frontend — not needed here

# ── Monitoring — Prometheus + PagerDuty ──────────────────────────────────────
PAGERDUTY_INTEGRATION_KEY=           # Events API v2 integration key
PAGERDUTY_CRITICAL_KEY=              # separate key for critical severity (optional)
OPS_EMAIL=ops@cryptodataapi.dev      # alert recipient email
