# =============================================
# CryptoFeed Pipeline Configuration
# =============================================

# Exchange API keys (optional - all data is from public endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM_MAXLEN=100000

# Data storage (use absolute path on VM e.g. /data)
DATA_DIR=./data
PARQUET_COMPRESSION=zstd

# Symbols to collect (comma-separated)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# Exchanges to enable
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_OKX=true

# Processor flush settings
PARQUET_FLUSH_ROWS=10000
PARQUET_FLUSH_SECS=60

# API server
# Set to true ONLY for local development (skips API key auth)
BYPASS_AUTH=false

# AI agents — get key at console.anthropic.com
ANTHROPIC_API_KEY=
