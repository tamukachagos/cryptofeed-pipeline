# Exchange API keys (optional - all collected data is from public endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM_MAXLEN=100000

# Data storage
DATA_DIR=./data
PARQUET_COMPRESSION=zstd

# Symbols to collect (comma-separated, use Binance format)
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# Exchanges to enable
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_OKX=true

# Processor flush settings
PARQUET_FLUSH_ROWS=10000
PARQUET_FLUSH_SECS=60
